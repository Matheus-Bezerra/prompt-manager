# Obrigatório para `pnpm test:e2e`: defina E2E_DATABASE_URL no `.env` ou no CI.
# O `DATABASE_URL` de desenvolvimento não é usado pelos testes E2E.
#
# Subir o Postgres de E2E (docker-compose → postgres_e2e, porta 5433):
#   docker compose up -d postgres_e2e
#
# Migrações na primeira vez (use a mesma URL do E2E):
#   DATABASE_URL="postgresql://postgres:password@localhost:5433/rocketseat_prompt_manager_e2e" pnpm exec prisma migrate deploy
#
E2E_DATABASE_URL="postgresql://postgres:password@localhost:5433/rocketseat_prompt_manager_e2e"
